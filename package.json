{
  "name": "agent-tracing-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm:dev:*\" --names \"NEXT,INGEST\" --prefix-colors \"blue,green\"",
    "dev:next": "next dev --webpack",
    "dev:ingest": "tsx watch ingest/index.ts",
    "build": "next build",
    "build:ingest": "tsc -p ingest/tsconfig.json",
    "start": "NODE_ENV=production node server/index.mjs",
    "start:ingest": "NODE_ENV=production node ingest/dist/ingest/index.js",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "typecheck:ingest": "tsc --noEmit -p ingest/tsconfig.json",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.1",
    "better-sqlite3": "^11.8.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.6.16",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.6.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.20.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
