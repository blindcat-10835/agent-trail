{
  "name": "agent-tracing-dashboard",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "dev": "concurrently -k --names \"INGEST,NEXT\" --prefix-colors \"green,blue\" \"npm:dev:ingest\" \"npm:dev:next\"",
    "dev:next": "next dev --webpack --port 3029",
    "dev:ingest": "INGEST_PORT=8077 tsx watch ingest/index.ts",
    "build": "next build --webpack",
    "build:ingest": "tsup ingest/index.ts --format cjs --out-dir ingest/dist --no-splitting --external better-sqlite3 --shims && cp ingest/db/schema.sql ingest/dist/schema.sql",
    "build:all": "pnpm build && pnpm build:ingest",
    "pack:npm": "pnpm build:all && node scripts/prepare-npm-package.mjs",
    "start": "next start --port 3029",
    "start:ingest": "INGEST_PORT=8077 NODE_ENV=production node ingest/dist/index.js",
    "start:all": "concurrently -k --names \"INGEST,NEXT\" --prefix-colors \"green,blue\" \"npm:start:ingest\" \"npm:start\"",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "typecheck:ingest": "tsc --noEmit -p ingest/tsconfig.json",
    "test": "vitest",
    "test:run": "vitest run",
    "test:real-sessions": "vitest run tests/local/real-session-corpus.test.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.1",
    "@tanstack/react-virtual": "^3.13.24",
    "better-sqlite3": "^12.10.0",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.6.16",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.20.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jsdom": "^29.1.1",
    "shadcn": "^4.6.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
